# Banco local ou URL do Postgres do Supabase (Settings → Database)
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/enam?schema=public"

# NextAuth.js — https://authjs.dev
# Em produção (ex.: Vercel), use URL absoluta com https:// — evita TypeError: Invalid URL
NEXTAUTH_URL=http://localhost:3000
# Auth.js v5 também lê AUTH_URL; na Vercel pode definir igual a NEXTAUTH_URL
AUTH_URL=
NEXTAUTH_SECRET=
# Google OAuth (Console Cloud → APIs e serviços → Credenciais)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
# Dashboard novo: publishable default key | legado: anon / public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."
# Alternativa: NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Servidor apenas: service_role ou secret key (nunca exponha no cliente)
SUPABASE_SERVICE_ROLE_KEY=""
# Alternativa ao nome acima (alguns dashboards usam "secret"):
# SUPABASE_SECRET_KEY=""

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
