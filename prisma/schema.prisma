// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Question {
  id          Int      @id @default(autoincrement())
  materia     String
  dificuldade String
  enunciado   String
  opcoes      String[]
  gabarito    String
  comentario  String
  fonte       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([materia])
  @@index([dificuldade])
}

/// Súmulas do STF persistidas (nome físico da tabela: `sumulasSTF`).
model SumulasSTF {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String
  dataAprovacao String @default("Não informado")
  fontePublicacao String @default("Não informado")
  referenciaLegislativa String @default("Não informado")
  precedentes String @default("Não informado")
  observacao String @default("Não informado")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sumulasSTF")
}

/// Súmulas do STJ persistidas (nome físico da tabela: `sumulasSTJ`).
model SumulasSTJ {
  id        Int      @id @default(autoincrement())
  titulo    String
  descricao String
  secao     String   @default("Não informado")
  julgadoEm String   @default("Não informado")
  djeDe     String   @default("Não informado")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sumulasSTJ")
}

/// Súmulas do TST persistidas (nome físico da tabela: `sumulasTST`).
model SumulasTST {
  id         Int      @id @default(autoincrement())
  titulo     String
  subtitulo  String   @default("")
  descricao  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("sumulasTST")
}

model UserSession {
  /// Identificador anônimo do usuário (gerado no browser e persistido via cookie/localStorage).
  sessionId            String @id
  questoesRespondidas  Int    @default(0)
  acertos               Int    @default(0)
  simuladosRealizados  Int    @default(0)
  diasSequenciaAtual    Int   @default(0)
  progressoPorMateria  Json  @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  simulados SimuladoAttempt[]
}

model SimuladoAttempt {
  id           Int      @id @default(autoincrement())
  sessionId   String
  qtdQuestoes Int
  tempoPorQSec Int
  acertos      Int      @default(0)
  respondidas  Int      @default(0)
  createdAt    DateTime @default(now())

  session UserSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId])
}

// NextAuth.js (Auth.js) — contas OAuth e credenciais (hash em `password`).
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
